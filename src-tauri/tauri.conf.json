{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S2shenDPI",
  "version": "4.0.0",
  "identifier": "com.shencim.s2shendpi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "S2shenDPI",
        "width": 380,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "devtools": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost https://api.github.com; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/s2shen-proxy",
      "binaries/s2shen-divert"
    ],
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libappindicator3-1", "iptables"]
      }
    }
  }
}
