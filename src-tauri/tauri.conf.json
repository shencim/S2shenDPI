{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S2shenDPI",
  "version": "4.0.0",
  "identifier": "com.shencim.s2shendpi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "S2shenDPI",
        "width": 380,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "devtools": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src ipc: http://ipc.localhost https://api.github.com; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/s2shen-proxy",
      "binaries/s2shen-divert"
    ],
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/WinDivert.dll": "WinDivert.dll",
      "binaries/WinDivert64.sys": "WinDivert64.sys",
      "binaries/npcap-installer.exe": "binaries/npcap-installer.exe"
    }
  }
}
